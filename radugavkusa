        <div style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:8px;margin-bottom:12px;">
          <div>
            <div style="font-family:'Bebas Neue';font-size:1.4rem;color:#fff;letter-spacing:1px;">Заказ #${orders.length-idx}</div>
            <div style="color:#888;font-size:.85rem;">${o.time}</div>
          </div>
          <select onchange="updateStatus(${o.id},this.value)" style="background:#222;border:1.5px solid ${statusColor};color:${statusColor};border-radius:10px;padding:6px 12px;font-weight:700;cursor:pointer;font-family:Nunito,sans-serif;">
            ${['Новый','Готовится','В пути','Доставлен'].map(s=>`<option value="${s}"${s===o.status?' selected':''}>${s}</option>`).join('')}
          </select>
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:6px;margin-bottom:12px;">
          <div style="background:#222;border-radius:10px;padding:10px;">
            <div style="color:#888;font-size:.75rem;margin-bottom:2px;">👤 Клиент</div>
            <div style="font-weight:700;">${o.name}</div>
          </div>
          <div style="background:#222;border-radius:10px;padding:10px;">
            <div style="color:#888;font-size:.75rem;margin-bottom:2px;">📞 Телефон</div>
            <div style="font-weight:700;">${o.phone}</div>
          </div>
        </div>
        <div style="background:#222;border-radius:10px;padding:10px;margin-bottom:12px;">
          <div style="color:#888;font-size:.75rem;margin-bottom:2px;">📍 Адрес</div>
          <div style="font-weight:700;">${o.addr}</div>
          ${o.comment?`<div style="color:#aaa;font-size:.85rem;margin-top:4px;">💬 ${o.comment}</div>`:''}
        </div>
        <div style="background:#1e1e1e;border-radius:10px;padding:10px;margin-bottom:12px;">
          <div style="color:#888;font-size:.75rem;margin-bottom:8px;">📦 Состав</div>
          ${o.items.map(i=>`<div style="display:flex;justify-content:space-between;padding:4px 0;border-bottom:1px solid #2a2a2a;font-size:.9rem;"><span>${i.name} × ${i.qty}</span><span style="color:#4cde6e;font-weight:700;">${i.price*i.qty>0?(i.price*i.qty).toLocaleString('ru-RU')+' сум':''}</span></div>`).join('')}
        </div>
        <div style="display:flex;justify-content:space-between;align-items:center;">
          <span style="color:#888;">Итого:</span>
          <span style="font-family:'Bebas Neue';font-size:1.6rem;color:#4cde6e;">${o.total.toLocaleString('ru-RU')} сум</span>
        </div>
      </div>`;
    });
  }
  html += `</div></div>`;
  document.body.insertAdjacentHTML('beforeend', html);
}

function updateStatus(id, status) {
  const orders = JSON.parse(localStorage.getItem('freshroll_orders')||'[]');
  const o = orders.find(x=>x.id===id);
  if (o) { o.status = status; localStorage.setItem('freshroll_orders', JSON.stringify(orders)); }
}

renderGrid('fresh');
</script>
</body>
</html>
