let cart = {};
const pizzaSizes = {};

function fmt(n) { return n.toLocaleString('ru-RU') + ' сум'; }

function renderGrid(key) {
  if (key === 'combo') { renderCombo(); return; }
  if (key === 'pizza') { renderPizza(); return; }
  const el = document.getElementById('grid-' + key);
  if (!el || el.dataset.rendered) return;
  el.dataset.rendered = '1';
  MENU[key].forEach(item => {
    const div = document.createElement('div');
    div.className = 'card';
    div.id = 'card-' + item.id;
    div.innerHTML = `
      <img class="card-img" src="${IMGS[item.id] || ''}" alt="${item.name}" onerror="this.outerHTML='<div class=card-img-placeholder>${item.emoji}</div>'">
      <div class="card-body">
        <div class="card-name">${item.name}</div>
        ${item.desc ? `<div class="card-desc">${item.desc}</div>` : ''}
        <div class="card-footer">
          <div class="card-price">${fmt(item.price)}</div>
          <div id="ctrl-${item.id}"><button class="add-btn" onclick="addItem('${item.id}','${item.name}',${item.price})">+</button></div>
        </div>
      </div>`;
    el.appendChild(div);
  });
}

function renderPizza() {
  const el = document.getElementById('grid-pizza');
  if (el.dataset.rendered) return;
  el.dataset.rendered = '1';
  const sizes = ['40 см','30 см','25 см'];
  MENU.pizza.forEach(item => {
    pizzaSizes[item.id] = 0;
    const div = document.createElement('div');
    div.className = 'card';
    div.id = 'card-' + item.id;
    div.innerHTML = `
      <img class="card-img" src="${IMGS[item.id] || ''}" alt="${item.name}" onerror="this.outerHTML='<div class=card-img-placeholder>${item.emoji}</div>'">
      <div class="card-body">
        <div class="card-name">${item.name}</div>
        <div class="size-tabs">
          ${sizes.map((s,i)=>`<button class="size-tab${i===0?' active':''}" onclick="setPizzaSize('${item.id}',${i},this)">${s}</button>`).join('')}
        </div>
        <div class="card-footer">
          <div class="card-price orange" id="pp-${item.id}">${fmt(item.prices[0])}</div>
          <div id="ctrl-${item.id}"><button class="add-btn" onclick="addPizza('${item.id}','${item.name}')">+</button></div>
        </div>
      </div>`;
    el.appendChild(div);
  });
}

function setPizzaSize(id, idx, btn) {
  pizzaSizes[id] = idx;
  btn.closest('.size-tabs').querySelectorAll('.size-tab').forEach((b,i)=>b.classList.toggle('active',i===idx));
  const item = MENU.pizza.find(p=>p.id===id);
  document.getElementById('pp-'+id).textContent = fmt(item.prices[idx]);
}

function addPizza(id, name) {
  const item = MENU.pizza.find(p=>p.id===id);
  const idx = pizzaSizes[id]||0;
  const sizes = ['40 см','30 см','25 см'];
  const fullName = name + ' ' + sizes[idx];
  const price = item.prices[idx];
  const key = id+'_'+idx;
  if (!cart[key]) cart[key] = { name: fullName, price, qty:0 };
  cart[key].qty++;
  updateCartCount();
  updateCardCtrl(id, key, fullName, price);
}

function renderCombo() {
  const el = document.getElementById('grid-combo');
  if (el.dataset.rendered) return;
  el.dataset.rendered = '1';
  MENU.combo.forEach(item => {
    const div = document.createElement('div');
    div.className = 'combo-card';
    div.innerHTML = `
      ${IMGS[item.id] ? `<img class="card-img" src="${IMGS[item.id]}" alt="${item.name}" style="width:100%;height:160px;object-fit:cover;border-radius:12px 12px 0 0;margin-bottom:12px;">` : ''}
      <div class="combo-name">${item.name}</div>
      ${item.qty ? `<div class="combo-qty">${item.qty}</div>` : ''}
      <div class="combo-items">${item.desc.split(',').map(s=>'• '+s.trim()).join('<br>')}</div>
      <div class="card-footer" style="margin-top:8px">
        <div class="card-price red">${fmt(item.price)}</div>
        <div id="ctrl-${item.id}"><button class="add-btn" onclick="addItem('${item.id}','${item.name}',${item.price})">+</button></div>
      </div>`;
    el.appendChild(div);
  });
}

function addItem(id, name, price) {
  if (!cart[id]) cart[id] = { name, price, qty:0 };
  cart[id].qty++;
  updateCartCount();
  updateCardCtrl(id, id, name, price);
}

function updateCardCtrl(id, key, name, price) {
  const ctrl = document.getElementById('ctrl-' + id);
  if (!ctrl) return;
  const qty = cart[key] ? cart[key].qty : 0;
  if (qty > 0) {
    ctrl.innerHTML = `<div class="qty-ctrl">
      <button onclick="removeItem('${id}','${key}','${name}',${price})">−</button>
      <span>${qty}</span>
      <button onclick="addItemKey('${key}')">+</button>
    </div>`;
  } else {
    ctrl.innerHTML = `<button class="add-btn" onclick="addItem('${id}','${name}',${price})">+</button>`;
  }
}

function addItemKey(key) {
  if (cart[key]) { cart[key].qty++; updateCartCount(); renderCartItems(); }
}

function removeItem(id, key, name, price) {
  if (!cart[key]) return;
  cart[key].qty--;
  if (cart[key].qty <= 0) delete cart[key];
  updateCartCount();
  updateCardCtrl(id, key, name, price);
  renderCartItems();
}

function updateCartCount() {
  const total = Object.values(cart).reduce((s,i)=>s+i.qty,0);
  document.getElementById('cartCount').textContent = total;
}

function showCat(key) {
  document.querySelectorAll('.menu-section').forEach(s=>s.classList.remove('active'));
  document.getElementById('cat-'+key).classList.add('active');
  document.querySelectorAll('.cat-btn').forEach(b=>b.classList.remove('active'));
  event.target.classList.add('active');
  renderGrid(key);
}

function openCart() {
  renderCartItems();
  document.getElementById('overlay').classList.add('open');
  document.body.style.overflow='hidden';
}
function closeCart() {
  document.getElementById('overlay').classList.remove('open');
  document.body.style.overflow='';
}
function closeCartOutside(e) { if (e.target===document.getElementById('overlay')) closeCart(); }

function renderCartItems() {
  const el = document.getElementById('cartItems');
  const keys = Object.keys(cart);
  if (!keys.length) { el.innerHTML='<div class="cart-empty">🍣 Корзина пуста</div>'; updateTotal(); return; }
  el.innerHTML = keys.map(key => {
    const it = cart[key];
    return `<div class="cart-item">
      <div class="cart-item-name">${it.name}</div>
      <div class="qty-ctrl">
        <button onclick="cartChange('${key}',-1)">−</button>
        <span>${it.qty}</span>
        <button onclick="cartChange('${key}',1)">+</button>
      </div>
      <div class="cart-item-price">${fmt(it.price*it.qty)}</div>
    </div>`;
  }).join('');
  updateTotal();
}

function cartChange(key, delta) {
  if (!cart[key]) return;
  cart[key].qty += delta;
  if (cart[key].qty <= 0) delete cart[key];
  updateCartCount();
  renderCartItems();
  const id = key.split('_')[0];
  const item = findItem(id);
  if (item && !item.prices) {
    updateCardCtrl(id, key, item.name, item.price);
  }
}

function findItem(id) {
  for (const cat of Object.values(MENU)) {
    const f = cat.find(i=>i.id===id);
    if (f) return f;
  }
  return null;
}

function updateTotal() {
  const total = Object.values(cart).reduce((s,i)=>s+i.price*i.qty,0);
  document.getElementById('totalPrice').textContent = fmt(total);
}

const TG_TOKEN = 'ВСТАВЬТЕ_ТОКЕН_БОТА';
const TG_CHAT_ID = 'ВСТАВЬТЕ_CHAT_ID';

async function submitOrder() {
  const name = document.getElementById('fName').value.trim();
  const phone = document.getElementById('fPhone').value.trim();
  const addr = document.getElementById('fAddress').value.trim();
  const comment = document.getElementById('fComment').value.trim();
  if (!name||!phone||!addr) { alert('Пожалуйста, заполните имя, телефон и адрес'); return; }
  if (!Object.keys(cart).length) { alert('Корзина пуста!'); return; }

  const btn = document.querySelector('.submit-btn');
  btn.textContent = '⏳ Отправка...'; btn.disabled = true;

  const items = Object.values(cart).map(i=>`• ${i.name} × ${i.qty} = ${fmt(i.price*i.qty)}`).join('\n');
  const total = Object.values(cart).reduce((s,i)=>s+i.price*i.qty,0);
  const now = new Date().toLocaleString('ru-RU');

  const msg = `🛒 *НОВЫЙ ЗАКАЗ* — ${now}\n\n👤 *Имя:* ${name}\n📞 *Телефон:* ${phone}\n📍 *Адрес:* ${addr}${comment?'\n💬 *Комментарий:* '+comment:''}\n\n📦 *Состав заказа:*\n${items}\n\n💰 *ИТОГО: ${fmt(total)}*`;

  const orders = JSON.parse(localStorage.getItem('freshroll_orders')||'[]');
  orders.unshift({ id: Date.now(), name, phone, addr, comment, items: Object.values(cart).map(i=>({...i})), total, time: now, status:'Новый' });
  localStorage.setItem('freshroll_orders', JSON.stringify(orders));

  if (TG_TOKEN !== 'ВСТАВЬТЕ_ТОКЕН_БОТА') {
    try {
      await fetch(`https://api.telegram.org/bot${TG_TOKEN}/sendMessage`, {
        method:'POST', headers:{'Content-Type':'application/json'},
        body: JSON.stringify({ chat_id: TG_CHAT_ID, text: msg, parse_mode:'Markdown' })
      });
    } catch(e) { console.warn('Telegram error', e); }
  }

  btn.textContent = '✅ Оформить заказ'; btn.disabled = false;
  document.getElementById('orderForm').style.display='none';
  document.getElementById('successMsg').style.display='block';
  cart = {};
  updateCartCount();
}

function resetOrder() {
  document.getElementById('orderForm').style.display='flex';
  document.getElementById('successMsg').style.display='none';
  document.getElementById('fName').value='';
  document.getElementById('fPhone').value='';
  document.getElementById('fAddress').value='';
  document.getElementById('fComment').value='';
  closeCart();
}

