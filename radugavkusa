<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Fresh Roll — Доставка суши и роллов</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
  :root {
    --green: #4cde6e;
    --red: #e63232;
    --orange: #f5a623;
    --bg: #111111;
    --card: #1a1a1a;
    --card2: #222222;
    --text: #f0f0f0;
    --muted: #888;
  }
  * { margin:0; padding:0; box-sizing:border-box; }
  body { background: var(--bg); color: var(--text); font-family: 'Nunito', sans-serif; min-height:100vh; }

  /* HEADER */
  header {
    position: sticky; top:0; z-index:100;
    background: rgba(10,10,10,0.97);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid #2a2a2a;
    padding: 0 20px;
    display: flex; align-items: center; justify-content: space-between;
    height: 64px;
  }
  .logo { font-family:'Bebas Neue'; font-size:2rem; color: var(--green); letter-spacing:2px; }
  .logo span { color: var(--red); }
  .cart-btn {
    background: var(--green); color: #111; border:none; border-radius:30px;
    padding: 10px 22px; font-family:'Nunito'; font-weight:800; font-size:1rem;
    cursor:pointer; display:flex; align-items:center; gap:8px; transition: transform .15s, background .15s;
  }
  .cart-btn:hover { background:#3bc45a; transform:scale(1.04); }
  .cart-count {
    background:#111; color: var(--green); border-radius:50%;
    width:22px; height:22px; display:flex; align-items:center; justify-content:center;
    font-size:.8rem; font-weight:800;
  }

  /* HERO */
  .hero {
    background: linear-gradient(135deg, #0f1f14 0%, #111 60%, #1a0a00 100%);
    padding: 60px 20px 50px;
    text-align: center;
    position: relative; overflow: hidden;
  }
  .hero::before {
    content:''; position:absolute; top:-60px; left:-60px; width:300px; height:300px;
    background: radial-gradient(circle, rgba(76,222,110,.12) 0%, transparent 70%);
    border-radius:50%;
  }
  .hero::after {
    content:''; position:absolute; bottom:-60px; right:-60px; width:250px; height:250px;
    background: radial-gradient(circle, rgba(230,50,50,.1) 0%, transparent 70%);
    border-radius:50%;
  }
  .hero h1 { font-family:'Bebas Neue'; font-size:clamp(3rem,10vw,6rem); color: var(--green); letter-spacing:4px; line-height:1; }
  .hero h1 span { color: #fff; }
  .hero p { color: var(--muted); font-size:1.1rem; margin: 12px 0 28px; }
  .hero-badges { display:flex; gap:12px; justify-content:center; flex-wrap:wrap; }
  .badge { background:#1e1e1e; border:1px solid #333; border-radius:20px; padding:6px 16px; font-size:.85rem; color:#ccc; }
  .badge span { color: var(--green); font-weight:700; }

  /* CATEGORIES NAV */
  .cat-nav {
    display:flex; gap:10px; overflow-x:auto; padding: 20px 16px;
    scrollbar-width:none; position:sticky; top:64px; z-index:90;
    background: rgba(17,17,17,.97); backdrop-filter:blur(8px);
    border-bottom: 1px solid #1e1e1e;
  }
  .cat-nav::-webkit-scrollbar { display:none; }
  .cat-btn {
    white-space:nowrap; padding:8px 18px; border-radius:20px;
    border: 1.5px solid #333; background:transparent; color:#bbb;
    font-family:'Nunito'; font-weight:700; font-size:.9rem; cursor:pointer;
    transition: all .2s;
  }
  .cat-btn:hover { border-color: var(--green); color: var(--green); }
  .cat-btn.active { background: var(--green); border-color: var(--green); color:#111; }

  /* MENU SECTION */
  .section { padding: 30px 16px; max-width:1100px; margin:0 auto; }
  .section-title {
    font-family:'Bebas Neue'; font-size:2.2rem; letter-spacing:3px;
    margin-bottom: 20px; padding-bottom:10px;
    border-bottom: 2px solid #2a2a2a;
    display:flex; align-items:center; gap:12px;
  }
  .section-title .dot { width:12px; height:12px; border-radius:50%; background: var(--green); }
  .section-title.red .dot { background: var(--red); }
  .section-title.orange .dot { background: var(--orange); }
  .section-title.blue .dot { background: #4a90e2; }
  .section-title.pink .dot { background: #e24ab0; }
  .section-title.yellow .dot { background: #f5d623; }

  /* GRID */
  .grid { display:grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap:16px; }

  /* CARD */
  .card {
    background: var(--card); border-radius:16px; overflow:hidden;
    border: 1px solid #2a2a2a; transition: transform .2s, border-color .2s;
    display:flex; flex-direction:column;
  }
  .card:hover { transform:translateY(-4px); border-color:#3a3a3a; }
  .card-img {
    width:100%; height:160px; object-fit:cover; display:block;
    background: #1e1e1e;
  }
  .card-img-placeholder {
    width:100%; height:160px; background: linear-gradient(135deg,#1e1e1e,#2a2a2a);
    display:flex; align-items:center; justify-content:center; font-size:3rem;
  }
  .card-body { padding:14px; flex:1; display:flex; flex-direction:column; gap:6px; }
  .card-name { font-weight:800; font-size:1rem; color:#fff; }
  .card-desc { font-size:.8rem; color: var(--muted); line-height:1.4; flex:1; }
  .card-footer { display:flex; align-items:center; justify-content:space-between; margin-top:10px; }
  .card-price { font-family:'Bebas Neue'; font-size:1.4rem; color: var(--green); letter-spacing:1px; }
  .card-price.red { color: var(--red); }
  .card-price.orange { color: var(--orange); }
  .add-btn {
    width:36px; height:36px; border-radius:50%; background: var(--green);
    border:none; color:#111; font-size:1.4rem; font-weight:700; cursor:pointer;
    display:flex; align-items:center; justify-content:center; transition: background .15s, transform .15s;
  }
  .add-btn:hover { background:#3bc45a; transform:scale(1.12); }
  .qty-ctrl { display:flex; align-items:center; gap:8px; }
  .qty-ctrl button {
    width:30px; height:30px; border-radius:50%; border:1.5px solid var(--green);
    background:transparent; color: var(--green); font-size:1.1rem; cursor:pointer; font-weight:700;
    transition: background .15s;
  }
  .qty-ctrl button:hover { background: var(--green); color:#111; }
  .qty-ctrl span { font-weight:800; min-width:18px; text-align:center; }

  /* PIZZA SIZES */
  .size-tabs { display:flex; gap:6px; margin-bottom:10px; }
  .size-tab {
    padding:4px 12px; border-radius:12px; border:1.5px solid #333;
    background:transparent; color:#888; font-family:'Nunito'; font-size:.8rem; font-weight:700; cursor:pointer;
    transition: all .15s;
  }
  .size-tab.active { border-color: var(--orange); color: var(--orange); }

  /* COMBO CARDS */
  .combo-card {
    background: linear-gradient(135deg, #1a0a0a, #1e1a10);
    border: 1px solid #3a2222; border-radius:16px; padding:20px;
    display:flex; flex-direction:column; gap:10px;
  }
  .combo-card .combo-name { font-family:'Bebas Neue'; font-size:1.6rem; color: var(--red); letter-spacing:2px; }
  .combo-card .combo-price { font-family:'Bebas Neue'; font-size:2rem; color:#fff; }
  .combo-card .combo-items { font-size:.85rem; color:#ccc; line-height:1.7; }
  .combo-card .combo-qty { color: var(--muted); font-size:.85rem; }

  /* CART MODAL */
  .overlay {
    display:none; position:fixed; inset:0; background:rgba(0,0,0,.8); z-index:200;
    backdrop-filter:blur(4px);
  }
  .overlay.open { display:flex; align-items:flex-end; justify-content:center; }
  @media(min-width:600px) { .overlay.open { align-items:center; } }
  .cart-modal {
    background: #171717; border-radius:20px 20px 0 0; width:100%; max-width:520px;
    max-height:90vh; display:flex; flex-direction:column;
    border: 1px solid #2a2a2a; border-bottom:none;
  }
  @media(min-width:600px) { .cart-modal { border-radius:20px; border-bottom:1px solid #2a2a2a; } }
  .cart-header {
    padding:20px; border-bottom:1px solid #2a2a2a;
    display:flex; justify-content:space-between; align-items:center;
  }
  .cart-header h2 { font-family:'Bebas Neue'; font-size:1.8rem; letter-spacing:2px; }
  .close-btn { background:#2a2a2a; border:none; color:#fff; width:34px; height:34px; border-radius:50%; font-size:1.2rem; cursor:pointer; }
  .cart-items { flex:1; overflow-y:auto; padding:16px; display:flex; flex-direction:column; gap:12px; }
  .cart-item { display:flex; gap:12px; align-items:center; background:#1e1e1e; border-radius:12px; padding:10px; }
  .cart-item-name { flex:1; font-weight:700; font-size:.9rem; }
  .cart-item-price { color: var(--green); font-family:'Bebas Neue'; font-size:1.1rem; }
  .cart-empty { text-align:center; color:var(--muted); padding:40px 0; font-size:1rem; }

  /* ORDER FORM */
  .order-form { padding:16px; border-top:1px solid #2a2a2a; display:flex; flex-direction:column; gap:10px; }
  .total-row { display:flex; justify-content:space-between; font-weight:800; font-size:1.1rem; }
  .total-row span:last-child { color: var(--green); font-family:'Bebas Neue'; font-size:1.4rem; }
  .form-row { display:grid; grid-template-columns:1fr 1fr; gap:8px; }
  .form-input {
    background:#1e1e1e; border:1.5px solid #333; border-radius:10px;
    padding:10px 14px; color:#fff; font-family:'Nunito'; font-size:.9rem; width:100%;
    transition: border-color .2s;
  }
  .form-input:focus { outline:none; border-color: var(--green); }
  .form-input.full { grid-column:1/-1; }
  .submit-btn {
    background: var(--green); color:#111; border:none; border-radius:12px;
    padding:14px; font-family:'Nunito'; font-weight:800; font-size:1.1rem;
    cursor:pointer; transition: background .15s, transform .1s;
    margin-top:4px;
  }
  .submit-btn:hover { background:#3bc45a; transform:scale(1.01); }
  .success-msg { display:none; text-align:center; padding:20px; }
  .success-msg .check { font-size:3rem; }
  .success-msg h3 { font-family:'Bebas Neue'; font-size:2rem; color: var(--green); letter-spacing:2px; margin-top:8px; }
  .success-msg p { color:var(--muted); margin-top:6px; }

  /* HIDDEN sections */
  .menu-section { display:none; }
  .menu-section.active { display:block; }

  /* SCROLLBAR */
  ::-webkit-scrollbar { width:6px; }
  ::-webkit-scrollbar-track { background:#111; }
  ::-webkit-scrollbar-thumb { background:#333; border-radius:3px; }
</style>
</head>
<body>

<header>
  <div class="logo">FRESH<span>ROLL</span></div>
  <div style="display:flex;gap:10px;align-items:center;">
    <button onclick="openAdmin()" style="background:#222;border:1.5px solid #333;color:#aaa;border-radius:30px;padding:8px 16px;font-family:Nunito,sans-serif;font-weight:700;font-size:.9rem;cursor:pointer;">📋 Заказы</button>
    <button class="cart-btn" onclick="openCart()">
      🛒 Корзина <span class="cart-count" id="cartCount">0</span>
    </button>
  </div>
</header>

<div class="hero">
  <h1>ДОСТАВКА <span>РОЛЛОВ</span></h1>
  <p>Свежие роллы, пицца и сеты прямо к вашей двери</p>
  <div class="hero-badges">
    <div class="badge">⏱ Доставка <span>40–60 мин</span></div>
    <div class="badge">🍣 Более <span>50 позиций</span></div>
  </div>
</div>

<nav class="cat-nav" id="catNav">
  <button class="cat-btn active" onclick="showCat('fresh')">🌿 Fresh Roll</button>
  <button class="cat-btn" onclick="showCat('baked')">🔥 Baked Roll</button>
  <button class="cat-btn" onclick="showCat('fride')">⚡ Fride Roll</button>
  <button class="cat-btn" onclick="showCat('classic')">🎋 Classic Roll</button>
  <button class="cat-btn" onclick="showCat('xl')">💥 XL Menu</button>
  <button class="cat-btn" onclick="showCat('kimbap')">🥢 Kimbap</button>
  <button class="cat-btn" onclick="showCat('pizza')">🍕 Pizza</button>
  <button class="cat-btn" onclick="showCat('combo')">🎁 Combo</button>
</nav>

<main style="max-width:1100px;margin:0 auto;">

<!-- FRESH ROLL -->
<div class="menu-section active" id="cat-fresh">
  <div class="section">
    <div class="section-title"><div class="dot"></div>FRESH ROLL</div>
    <div class="grid" id="grid-fresh"></div>
  </div>
</div>

<!-- BAKED ROLL -->
<div class="menu-section" id="cat-baked">
  <div class="section">
    <div class="section-title red"><div class="dot"></div>BAKED ROLL</div>
    <div class="grid" id="grid-baked"></div>
  </div>
</div>

<!-- FRIDE ROLL -->
<div class="menu-section" id="cat-fride">
  <div class="section">
    <div class="section-title orange"><div class="dot"></div>FRIDE ROLL</div>
    <div class="grid" id="grid-fride"></div>
  </div>
</div>

<!-- CLASSIC ROLL -->
<div class="menu-section" id="cat-classic">
  <div class="section">
    <div class="section-title blue"><div class="dot"></div>CLASSIC ROLL</div>
    <div class="grid" id="grid-classic"></div>
  </div>
</div>

<!-- XL MENU -->
<div class="menu-section" id="cat-xl">
  <div class="section">
    <div class="section-title pink"><div class="dot"></div>BIG SIZE XL MENU</div>
    <div class="grid" id="grid-xl"></div>
  </div>
</div>

<!-- KIMBAP -->
<div class="menu-section" id="cat-kimbap">
  <div class="section">
    <div class="section-title yellow"><div class="dot"></div>KIMBAP</div>
    <div class="grid" id="grid-kimbap"></div>
  </div>
</div>

<!-- PIZZA -->
<div class="menu-section" id="cat-pizza">
  <div class="section">
    <div class="section-title orange"><div class="dot"></div>PIZZA (40/30/25 см)</div>
    <div class="grid" id="grid-pizza"></div>
  </div>
</div>

<!-- COMBO -->
<div class="menu-section" id="cat-combo">
  <div class="section">
    <div class="section-title red"><div class="dot"></div>COMBO SETS</div>
    <div class="grid" id="grid-combo" style="grid-template-columns:repeat(auto-fill,minmax(280px,1fr))"></div>
  </div>
</div>

</main>

<!-- CART OVERLAY -->
<div class="overlay" id="overlay" onclick="closeCartOutside(event)">
  <div class="cart-modal" id="cartModal">
    <div class="cart-header">
      <h2>🛒 КОРЗИНА</h2>
      <button class="close-btn" onclick="closeCart()">✕</button>
    </div>
    <div class="cart-items" id="cartItems">
      <div class="cart-empty">Корзина пуста</div>
    </div>
    <div class="order-form" id="orderForm">
      <div class="total-row"><span>Итого:</span><span id="totalPrice">0 сум</span></div>
      <div class="form-row">
        <input class="form-input" id="fName" placeholder="Ваше имя *" required>
        <input class="form-input" id="fPhone" placeholder="Телефон *" required>
      </div>
      <input class="form-input full" id="fAddress" placeholder="Адрес доставки *" required>
      <textarea class="form-input full" id="fComment" placeholder="Комментарий к заказу" rows="2" style="resize:none;"></textarea>
      <button class="submit-btn" onclick="submitOrder()">✅ Оформить заказ</button>
    </div>
    <div class="success-msg" id="successMsg">
      <div class="check">✅</div>
      <h3>ЗАКАЗ ПРИНЯТ!</h3>
      <p>Мы свяжемся с вами в ближайшее время.<br>Ожидайте доставку через 40–60 минут.</p>
      <button class="submit-btn" onclick="resetOrder()" style="margin-top:16px;">Сделать ещё заказ</button>
    </div>
  </div>
</div>

